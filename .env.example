# ─────────────────────────────────────────────────────────
# MiseMap — Environment Variables
# Built by Sayv Ilahsiav · apps.sayvilahsiav.com
# ─────────────────────────────────────────────────────────
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in your credentials below
# 3. Add the same variables to Vercel → Project Settings → Environment Variables
# 4. Never commit .env to git — it is already in .gitignore

# From: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# From: console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
